{
  "name": "factory-master: error-handler",
  "active": false,
  "nodes": [
    {
      "parameters": {},
      "id": "eh000000-0000-0000-0000-000000000001",
      "name": "On Workflow Error",
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [220, 320]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://factory-master-actions-mcp-140345952904.me-west1.run.app/factory/@@SYSTEM_NAME@@/emit",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpBearerAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ name: 'factory.n8n.workflow_failed', severity: 'error', action_required: true, body: { workflow: $json.workflow?.name, workflow_id: $json.workflow?.id, node: $json.execution?.lastNodeExecuted, error: String($json.execution?.error?.message || '').slice(0, 500), execution_id: $json.execution?.id, execution_url: $json.execution?.url, mode: $json.execution?.mode } }) }}",
        "options": { "timeout": 10000 }
      },
      "id": "eh000000-0000-0000-0000-000000000002",
      "name": "Emit workflow_failed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 320],
      "credentials": {
        "httpBearerAuth": { "id": "@@CRED_FACTORY_MCP_ID@@", "name": "Factory MCP" }
      },
      "onError": "continueRegularOutput"
    }
  ],
  "connections": {
    "On Workflow Error": {
      "main": [
        [
          {
            "node": "Emit workflow_failed",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
