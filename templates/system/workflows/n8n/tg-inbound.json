    "Ack Approve": { "main": [[{ "node": "Prep Executor Input", "type": "main", "index": 0 }]] },
    "Prep Executor Input": { "main": [[{ "node": "Run Executor", "type": "main", "index": 0 }]] },
    "Ack Reject": { "main": [[{ "node": "Mark Rejected", "type": "main", "index": 0 }]] },
    "Call Agent Router": { "main": [[{ "node": "Send Reply", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
