              "name": "ok",
              "type": "boolean",
              "value": "=false"
            },
            {
              "id": "73000000-0000-0000-0000-000000000002",
              "name": "command",
              "type": "string",
              "value": "={{ $('Normalize Input').first().json.command }}"
