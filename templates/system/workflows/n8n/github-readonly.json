{
  "name": "factory-master: github-readonly",
  "active": false,
  "nodes": [
    {
      "parameters": { "inputSource": "passthrough" },
      "id": "70000000-0000-0000-0000-000000000001",
      "name": "When Executed by Another Workflow",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [220, 360]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Normalize the LLM's tool args into a uniform { command } shape.\n// Mirrors postgres-named-queries 'Normalize Input' (Stage 113): the toolWorkflow\n// node uses specifyInputSchema:false, so the LLM passes a single RAW STRING as the\n// tool's arg. With the trigger in passthrough mode that string arrives at\n// $json.query. Valid commands: ci_runs | recent_commits | open_prs.\nconst items = $input.all();\nconst raw = (items[0] && items[0].json) || {};\nconst valid = ['ci_runs', 'recent_commits', 'open_prs'];\nconst tryString = (s) => {\n  if (typeof s !== 'string') return '';\n  const t = s.trim();\n  if (!t) return '';\n  if (valid.indexOf(t) >= 0) return t;\n  try { const p = JSON.parse(t); if (p && typeof p.command === 'string') return p.command; } catch (e) { /* ignore */ }\n  return '';\n};\nlet cmd = '';\nif (typeof raw.command === 'string' && raw.command) {\n  cmd = valid.indexOf(raw.command.trim()) >= 0 ? raw.command.trim() : tryString(raw.command);\n} else if (typeof raw.query === 'string') {\n  cmd = tryString(raw.query);\n} else if (raw.query && typeof raw.query === 'object' && typeof raw.query.command === 'string') {\n  cmd = raw.query.command;\n} else if (raw.input && typeof raw.input.command === 'string') {\n  cmd = raw.input.command;\n} else if (typeof raw.arguments === 'string') {\n  cmd = tryString(raw.arguments);\n}\nreturn [{ json: { command: cmd, _raw_input: raw } }];"
      },
      "id": "70000000-0000-0000-0000-00000000000a",
      "name": "Normalize Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [400, 360]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Reuse a cached installation token across executions to avoid minting on every\n// call. Tokens live 1h; refresh only when within 5 min (300s) of expiry. The\n// token is treated as an OPAQUE string — no length/format assumptions (GitHub's\n// 2026 stateless tokens are ~520 chars and growing).\nconst sd = $getWorkflowStaticData('global');\nconst cache = (sd && sd.github_token_cache) || {};\nconst now = Math.floor(Date.now() / 1000);\nconst valid = !!(cache.token && cache.exp && (cache.exp - now > 300));\nif (valid) {\n  return [{ json: { cached: true, token: cache.token, exp: cache.exp } }];\n}\nreturn [{ json: { cached: false } }];"
      },
      "id": "70000000-0000-0000-0000-000000000002",
      "name": "Token Cache Check",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [600, 360]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose", "version": 2 },
          "combinator": "and",
          "conditions": [
            {
              "id": "71000000-0000-0000-0000-000000000001",
              "leftValue": "={{ $json.cached }}",
              "rightValue": "",
              "operator": { "type": "boolean", "operation": "true", "singleValue": true }
            }
          ]
        },
        "options": {}
      },
      "id": "70000000-0000-0000-0000-000000000003",
      "name": "Token Valid?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [800, 360]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Build the GitHub App JWT claims. iat backdated 60s for clock skew; exp 9 min\n// (GitHub max is 10). iss is the App ID, injected at install time as a non-secret\n// placeholder. The signing itself happens in the built-in JWT node (RS256 + PEM\n// credential) so the n8n container does NOT need NODE_FUNCTION_ALLOW_BUILTIN=crypto.\nconst now = Math.floor(Date.now() / 1000);\nreturn [{ json: { iat: now - 60, exp: now + 540, iss: '@@GITHUB_APP_ID@@' } }];"
      },
      "id": "70000000-0000-0000-0000-000000000004",
      "name": "Build JWT Claims",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [800, 540]
    },
    {
      "parameters": {
        "operation": "sign",
        "useJson": true,
        "claimsJson": "={{ JSON.stringify({ iat: $json.iat, exp: $json.exp, iss: $json.iss }) }}",
        "options": {}
      },
      "id": "70000000-0000-0000-0000-000000000005",
      "name": "Sign JWT",
      "type": "n8n-nodes-base.jwt",
      "typeVersion": 1,
      "position": [1000, 540],
      "credentials": { "jwtAuth": { "id": "@@CRED_GITHUB_JWT_ID@@", "name": "GitHub App JWT (RS256)" } }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.github.com/app/installations/@@GITHUB_INSTALLATION_ID@@/access_tokens",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $json.token }}" },
            { "name": "Accept", "value": "application/vnd.github+json" },
            { "name": "X-GitHub-Api-Version", "value": "2022-11-28" }
          ]
        },
        "options": {}
      },
      "id": "70000000-0000-0000-0000-000000000006",
      "name": "Mint Installation Token",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1200, 540],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Persist the freshly-minted installation token in workflow static data so the\n// next execution reuses it (Token Cache Check). exp from GitHub's expires_at\n// (ISO) → epoch seconds; fall back to now+50min if missing. Token kept opaque.\nconst resp = ($input.first() && $input.first().json) || {};\nconst token = resp.token || '';\nconst exp = resp.expires_at ? Math.floor(new Date(resp.expires_at).getTime() / 1000) : (Math.floor(Date.now() / 1000) + 3000);\nconst sd = $getWorkflowStaticData('global');\nsd.github_token_cache = { token: token, exp: exp };\nreturn [{ json: { cached: false, token: token, exp: exp } }];"
      },
      "id": "70000000-0000-0000-0000-000000000007",
      "name": "Cache Token",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1400, 540]
    },
