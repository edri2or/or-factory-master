    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Flatten whichever GitHub branch ran into a uniform tool response, keeping\n// html_url links intact (links are allowed downstream — the router egress\n// allow-list permits github.com). command comes from Normalize Input. A GitHub\n// REST error arrives as a single { message, documentation_url } object → ok:false.\nconst command = String($('Normalize Input').first().json.command || '');\nconst items = $input.all().map(i => i && i.json).filter(Boolean);\nconst firstObj = items[0] || {};\nlet ok = true;\nlet data = items;\nif (firstObj && typeof firstObj.message === 'string' && (firstObj.documentation_url || firstObj.status)) {\n  ok = false;\n  data = firstObj;\n} else if (command === 'ci_runs') {\n  data = (firstObj && Array.isArray(firstObj.workflow_runs)) ? firstObj.workflow_runs : items;\n} else {\n  data = items;\n}\nreturn [{ json: { ok: ok, command: command, data: data } }];"
      },
      "id": "70000000-0000-0000-0000-00000000000d",
      "name": "Format Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2100, 360]
    },
