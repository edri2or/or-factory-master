    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Normalize the LLM's tool args into a uniform { query_name } shape.\n// Stage 113 (verified end-to-end on tgbot15 with the operator's real Telegram\n// message): the toolWorkflow node has `specifyInputSchema:false`, so the LLM\n// passes a single RAW STRING as the tool's arg (no JSON wrapping). With the\n// trigger in passthrough mode, that string arrives at $json.query. Stage 110's\n// workflowInputs path + Stage 112's schemaType:\"fromJson\" both failed (the LLM\n// kept sending query_name:null in those modes — confirmed via DEBUG1+DEBUG2\n// Telegram messages on tgbot14/15). This normalizer tries every observed shape\n// in order so the Switch downstream can read `$json.query_name` uniformly.\nconst items = $input.all();\nconst raw = (items[0] && items[0].json) || {};\nconst valid = ['style_profile_get', 'recent_audit_log', 'pending_actions_open', 'executions_summary_24h', 'spend_total'];\nconst tryString = (s) => {\n  if (typeof s !== 'string') return '';\n  const t = s.trim();\n  if (!t) return '';\n  if (valid.indexOf(t) >= 0) return t;\n  try { const p = JSON.parse(t); if (p && typeof p.query_name === 'string') return p.query_name; } catch (e) { /* ignore */ }\n  return '';\n};\nlet qn = '';\nif (typeof raw.query_name === 'string' && raw.query_name) {\n  qn = raw.query_name;\n} else if (typeof raw.query === 'string') {\n  qn = tryString(raw.query);\n} else if (raw.query && typeof raw.query === 'object' && typeof raw.query.query_name === 'string') {\n  qn = raw.query.query_name;\n} else if (raw.input && typeof raw.input.query_name === 'string') {\n  qn = raw.input.query_name;\n} else if (typeof raw.arguments === 'string') {\n  qn = tryString(raw.arguments);\n}\nreturn [{ json: { query_name: qn, _raw_input: raw } }];"
      },
