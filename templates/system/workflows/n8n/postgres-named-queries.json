    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Normalize the LLM's tool args into a uniform { query_name } shape.\n// n8n's toolWorkflow v2.1 may deliver args at any of several locations\n// depending on the toolWorkflow's schemaType setting and the trigger's\n// inputSource — Stage 110's workflowInputs fix alone didn't surface the\n// LLM-supplied value (every postgres-named-queries execution on tgbot13\n// still fell to the 'Unknown Query' branch with run-time under 30ms).\n// This normalizer is defensive against ALL observed shapes and also emits\n// `_raw_input` so future executions show what actually arrived.\nconst raw = ($input.first() && $input.first().json) || {};\nlet qn = '';\nif (typeof raw.query_name === 'string' && raw.query_name) {\n  qn = raw.query_name;\n} else if (raw.input && typeof raw.input.query_name === 'string') {\n  qn = raw.input.query_name;\n} else if (raw.query && typeof raw.query === 'object' && typeof raw.query.query_name === 'string') {\n  qn = raw.query.query_name;\n} else if (typeof raw.query === 'string') {\n  try { const p = JSON.parse(raw.query); if (p && typeof p.query_name === 'string') qn = p.query_name; } catch (e) { /* ignore */ }\n} else if (typeof raw.arguments === 'string') {\n  try { const p = JSON.parse(raw.arguments); if (p && typeof p.query_name === 'string') qn = p.query_name; } catch (e) { /* ignore */ }\n}\nreturn [{ json: { query_name: qn, _raw_input: raw } }];"
      },
      "id": "50000000-0000-0000-0000-00000000000a",
