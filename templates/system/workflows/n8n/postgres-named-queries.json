    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT ROUND(COALESCE((SELECT last_cum_usd FROM spend_track_state LIMIT 1),0),4) AS total_usd,\n       (SELECT updated_at FROM spend_track_state LIMIT 1) AS as_of,\n       ROUND(COALESCE((SELECT SUM(cost_usd) FROM spend_log),0),4) AS logged_usd,\n       (SELECT COUNT(*)::int FROM spend_log) AS log_rows;",
        "options": {}
      },
