        [{ "node": "Build Success", "type": "main", "index": 0 }],
        [{ "node": "Build Failure", "type": "main", "index": 0 }]
      ]
    },
    "GH Build JWT Claims": { "main": [[{ "node": "GH Sign JWT", "type": "main", "index": 0 }]] },
    "GH Sign JWT": { "main": [[{ "node": "GH Mint Token", "type": "main", "index": 0 }]] },
    "GH Mint Token": {
      "main": [
        [{ "node": "GH Build Dispatch", "type": "main", "index": 0 }],
