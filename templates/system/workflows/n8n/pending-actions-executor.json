      ]
    },
    "GH Build Dispatch": { "main": [[{ "node": "GH Dispatch", "type": "main", "index": 0 }]] },
    "GH Dispatch": {
      "main": [
        [{ "node": "Build Success", "type": "main", "index": 0 }],
        [{ "node": "Build Failure", "type": "main", "index": 0 }]
      ]
    },
    "Build Success": { "main": [[{ "node": "Mark Done", "type": "main", "index": 0 }]] },
    "Mark Done": { "main": [[{ "node": "Notify Success", "type": "main", "index": 0 }]] },
    "Build Failure": { "main": [[{ "node": "Mark Failed", "type": "main", "index": 0 }]] },
    "Mark Failed": { "main": [[{ "node": "Notify Failure", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}
