    "sendHeaders": false,
    "sendBody": false,
    "optimizeResponse": true,
    "responseType": "json",
    "dataField": "data",
    "fieldsToInclude": "selected",
    "fields": "id, name, active"
  },
  "id": "b0000000-0000-0000-0000-000000000005",
  "name": "n8n API",
  "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
  "typeVersion": 1.1,
  "position": [
    640,
    560
  ],
  "credentials": {
    "httpHeaderAuth": {
      "id": "@@CRED_N8N_API_ID@@",
      "name": "n8n Public API (X-N8N-API-KEY)"
    }
  }
