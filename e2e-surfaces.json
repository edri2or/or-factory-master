{
  "version": 1,
  "_doc": "E2E surface registry — the risk-tiered, per-surface generalization of the E2E verification gate. See docs/e2e-enforcement-standard.md. Paths are system-relative; in the factory repo a scope=system surface is matched/hashed under templates/system/. Only enforce=true surfaces become required status checks. Optional proof_systems[] pins the live proof to a specific standing proving system (the factory rule: prove on or-edri-4 first, then lock into the template) — a proof from any other system is rejected; absent field = any system.",
  "surfaces": [
    {
      "id": "telegram-bot",
      "name_he": "בוט inbound (agent-router)",
      "risk_tier": "critical",
      "scope": "system",
      "trigger_paths": [
        "workflows/n8n/*.json",
        ".github/workflows/configure-agent-router.yml"
      ],
      "proof_producer": "e2e-verify.yml",
      "proof_glob": "e2e-proofs/*.json",
      "hash_inputs": [
        "workflows/n8n/*.json",
        ".github/workflows/configure-agent-router.yml"
      ],
      "freshness_days": 14,
      "proof_systems": ["or-edri-4"],
      "enforce": true
    },
    {
      "id": "deploy-edge",
      "name_he": "קצה Caddy/HMAC (deploy)",
      "risk_tier": "high",
      "scope": "system",
      "trigger_paths": [
        "Caddyfile",
        "Dockerfile.caddy",
        "caddy/hmacguard/*.go",
        "caddy/hmacguard/go.mod",
        ".github/workflows/deploy-railway-cloudflare.yml"
      ],
      "proof_producer": "deploy-verify.yml",
      "proof_glob": "e2e-proofs/deploy-edge-*.json",
      "hash_inputs": [
        "Caddyfile",
        "Dockerfile.caddy",
        "caddy/hmacguard/*.go",
        "caddy/hmacguard/go.mod",
        ".github/workflows/deploy-railway-cloudflare.yml"
      ],
      "freshness_days": 30,
      "proof_systems": ["or-edri-4"],
      "enforce": true
    },
    {
      "id": "factory-mcp",
      "name_he": "שער MCP טלמטריה (/factory)",
      "risk_tier": "high",
      "scope": "factory",
      "gate": "deploy",
      "trigger_paths": ["services/mcp-server/src/factory-scope.ts", "services/mcp-server/src/tools.ts"],
      "proof_producer": "factory-mcp-smoke.yml",
      "deploy_smoke": "scripts/factory-mcp-smoke.py",
      "freshness_days": 30,
      "enforce": false
    },
    {
      "id": "n8n-mcp",
      "name_he": "שער MCP n8n live (/n8n)",
      "risk_tier": "high",
      "scope": "factory",
      "gate": "deploy",
      "trigger_paths": ["services/mcp-server/src/n8n-client.ts"],
      "proof_producer": "n8n-mcp-smoke.yml",
      "deploy_smoke": "scripts/n8n-mcp-smoke.py",
      "freshness_days": 30,
      "enforce": false
    },
    {
      "id": "workspace-mcp",
      "name_he": "שער MCP Google Workspace (/workspace)",
      "risk_tier": "high",
      "scope": "factory",
      "gate": "deploy",
      "trigger_paths": ["services/mcp-server/src/google-oauth.ts"],
      "proof_producer": "google-mcp-smoke.yml",
      "deploy_smoke": "scripts/google-mcp-smoke.py",
      "freshness_days": 30,
      "enforce": false
    },
    {
      "id": "observability-delivery",
      "name_he": "מסירת אירועים (Axiom/Telegram/Linear)",
      "risk_tier": "medium",
      "scope": "factory",
      "gate": "advisory",
      "trigger_paths": ["scripts/emit-event.sh", "scripts/lib/*.sh"],
      "proof_producer": "(future)",
      "_note": "emit-event.sh is soft-fail by design (a dead sink never fails the caller), so delivery is never proven. ADVISORY/future: a synthetic emit -> Axiom read-back (see services/mcp-server/src/observability-client.ts) would prove delivery. Not enforced; documented in docs/e2e-enforcement-standard.md as a future producer.",
      "freshness_days": 30,
      "enforce": false
    }
  ]
}
